{
  "expo": {
    "name": "devel.",
    "slug": "photobooth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "photobooth",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.photobooth.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We need access to your camera to take photobooth pictures.",
        "NSPhotoLibraryAddUsageDescription": "Save your photobooth pictures to your gallery.",
        "NSPhotoLibraryUsageDescription": "Access your gallery to share photobooth pictures."
      }
    },
    "android": {
      "package": "com.photobooth.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF5F0"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-media-library",
      "expo-splash-screen"
    ]
  }
}
